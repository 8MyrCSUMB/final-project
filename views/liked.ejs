<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/navbarLoggedIn.ejs')%>

            <div class="container py-5" style="max-width: 700px;">

                <h1 class="fw-bold mb-4 text-center">
                    <i class="bi bi-heart-fill text-danger me-2"></i>Liked Songs
                </h1>

                <% if (rows2 && rows2.length> 0) { %>
                    <p class="text-muted text-center mb-4">
                        <%= rows2.length %> song<%= rows2.length> 1 ? 's' : '' %>
                    </p>

                    <% for(let i in rows2) { %>
                        <div class="card mb-3 border-0 bg-body-secondary">
                            <div class="row g-0 align-items-center">
                                <div class="col-auto">
                                    <img src="<%= rows2[i].pictureLink %>" class="rounded-start"
                                        style="width:80px; height:80px; object-fit:cover;">
                                </div>
                                <div class="col px-3">
                                    <p class="text-muted small mb-0 text-uppercase fw-semibold">
                                        <%= rows2[i].artistName %>
                                    </p>
                                    <p class="fw-bold mb-1">
                                        <%= rows2[i].songName %>
                                    </p>
                                    <audio src="<%= rows2[i].musicLink %>" controls
                                        style="height:30px; width:100%;"></audio>
                                </div>
                            </div>
                        </div>
                        <% } %>
                            <% } else { %>
                                <div class="text-center text-muted py-5">
                                    <i class="bi bi-heart display-4 d-block mb-3 opacity-25"></i>
                                    <p>No liked songs yet. <a href="/search" class="text-info">Search for music</a> to
                                        get started.</p>
                                </div>
                                <% } %>

            </div>

            <%- include('partials/footer.ejs')%>
    </body>

</html>