<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/navbarAdmin.ejs')%>

            <div class="container mt-4">
                <h1 class="display-4 fw-bold text-center">All Users</h1>

                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>DoB</th>
                            <th>Sex</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let i of rows) { const date=i.dob ? new Date(i.dob).toISOString().split('T')[0] : '' ; %>
                            <tr>
                                <form action="/updateUser" method="POST">
                                    <input type="hidden" name="userId" value="<%= i.userId %>">

                                    <td>
                                        <%= i.userId %>
                                    </td>
                                    <td><input type="text" name="username" value="<%= i.username %>"
                                            class="form-control" required></td>
                                    <td><input type="email" name="email" value="<%= i.email %>" class="form-control"
                                            required></td>
                                    <td><input type="text" name="firstname" value="<%= i.firstname %>"
                                            class="form-control" required></td>
                                    <td><input type="text" name="lastname" value="<%= i.lastname %>"
                                            class="form-control" required></td>
                                    <td><input type="date" name="dob" value="<%= date %>" class="form-control" required>
                                    </td>
                                    <td>
                                        <select name="sex" class="form-select" required>
                                            <% ['M', 'F' , 'O' ].forEach(opt=> { %>
                                                <option value="<%= opt %>" <%=i.sex===opt ? 'selected' : '' %>><%= opt
                                                        %>
                                                </option>
                                                <% }) %>
                                        </select>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-success btn-sm">Update</button>
                                            <a href="/deleteUser?userId=<%= i.userId %>"
                                                class="btn btn-danger btn-sm">Delete</a>
                                        </div>
                                    </td>
                                </form>
                            </tr>
                            <% } %>
                    </tbody>
                </table>

                <% if (locals.errorMessage) { %>
                    <div class="alert alert-danger text-center">
                        <%= errorMessage %>
                    </div>
                    <% } %>
            </div>

            <%- include('partials/footer.ejs')%>
    </body>

</html>