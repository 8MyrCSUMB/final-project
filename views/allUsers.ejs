<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<%- include('partials/head.ejs') %>


    <body>
        <%- include('partials/navbarAdmin.ejs')%>

            <h1 class="display-4 fw-bold text-center">All Users</h1>
            <div class="container mt-4">
                <table class="table table-striped align-middle">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let i of rows) { %>
                            <tr>
                                <form action="/updateUser" method="POST">
                                    <td>
                                        <%= i.userId %>
                                            <input type="hidden" name="userId" value="<%= i.userId %>">
                                    </td>
                                    <td><input type="text" name="username" value="<%= i.username %>"
                                            class="form-control" <%=i.username===currentUsername ? 'readonly' : '' %>
                                        required></td>
                                    <td><input type="email" name="email" value="<%= i.email %>" class="form-control"
                                            <%=i.username===currentUsername ? 'readonly' : '' %> required></td>
                                    <td><input type="text" name="firstname" value="<%= i.firstname %>"
                                            class="form-control" <%=i.username===currentUsername ? 'readonly' : '' %>
                                        required></td>
                                    <td><input type="text" name="lastname" value="<%= i.lastname %>"
                                            class="form-control" <%=i.username===currentUsername ? 'readonly' : '' %>
                                        required></td>
                                    <td>
                                        <div class="d-flex gap-2">
                                            <% if (i.username !==currentUsername) { %>
                                                <button type="submit" class="btn btn-success">Update</button>
                                                <a href="/deleteUser?userId=<%= i.userId %>"
                                                    class="btn btn-danger">Delete</a>
                                                <% } else { %>
                                                    <span class="text-muted">Active</span>
                                                    <% } %>
                                        </div>
                                    </td>
                                </form>
                            </tr>
                            <% } %>
                    </tbody>
                </table>
            </div>
            <%- include('partials/footer.ejs')%>
    </body>

</html>