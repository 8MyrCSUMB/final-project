<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<%- include('partials/head.ejs') %>

    <body class="text-center">

        <%- include('partials/navbar.ejs')%>

            <div class="container py-5">
                <header class="py-5">
                    <h1 class="display-1 fw-bold">MusicaBox</h1>
                    <p class="lead fs-4 text-secondary">Discover, listen, and organize your favorite tracks all in one place.</p>
                </header>

                <div class="row row-cols-1 row-cols-md-3 g-4 my-5">
                    <div class="col">
                        <div class="card h-100 border-0 bg-transparent">
                            <div class="card-body">
                                <h3 class="fw-semibold">Discover Music</h3>
                                <p class="text-muted">Search for any artist, album, or track and explore an endless world of music instantly.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 border-0 bg-transparent">
                            <div class="card-body">
                                <h3 class="fw-semibold">Preview Tracks</h3>
                                <p class="text-muted">Not sure if it's the right song? Listen to quick audio previews before adding them to your collection.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100 border-0 bg-transparent">
                            <div class="card-body">
                                <h3 class="fw-semibold">Save Favorites</h3>
                                <p class="text-muted">Keep track of the songs you love and build your own personalized music library.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row justify-content-center">
                    <div class="col-md-8 text-start">
                        <hr class="my-5 opacity-25">
                        <h2 class="h4 fw-bold">Overview</h2>
                        <p>Welcome to MusicaBox, your ultimate destination for music discovery. Whether you are searching for the latest hits, exploring new genres, or simply enjoying your timeless favorites, MusicaBox provides a seamless and immersive musical experience.</p>
                    </div>
                </div>
            </div>

            <%- include('partials/footer.ejs')%>
    </body>

</html>