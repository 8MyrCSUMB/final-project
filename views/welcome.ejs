<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<%- include('partials/head.ejs') %>


    <body>

        <%- include('partials/navbarLoggedIn.ejs')%>
            <canvas id="vanillaConfettiCanvas"></canvas>


            <h1 class="text-center">Welcome <%= fullName %> !
            </h1>
            <h2 class="text-center">Explore our website to search, listen and like thousands of musics ! </h2>
            <hr>
            <h3 class="text-center">Here are the next shows : </h3>
            <div class="container mt-4">

                <div class="row">

                    <% if (data._embedded && data._embedded.events) { %>
                        <% for(let i of data._embedded.events) { %>
                            <div class="col-md-8 mx-auto mb-4">
                                <div class="card flex-md-row shadow-sm">
                                    <img src="<%= i.images && i.images.length > 0 ? i.images[0].url : '' %>"
                                        class="card-img-left" style="width: 100%; max-width: 300px; object-fit: cover;"
                                        alt="">
                                    <div class="card-body d-flex flex-column justify-content-center">
                                        <h5 class="card-title">
                                            <%= i.name %>
                                        </h5>
                                        <p class="card-text">
                                            <%= i.dates && i.dates.start ? i.dates.start.localDate : 'TBD' %>
                                        </p>
                                        <p class="card-text">
                                            <%= i._embedded.venues[0].city.name || 'Location TBD' %>
                                        </p>
                                        <div>
                                            <a href="<%= i.url %>" class="btn btn-primary">Buy Tickets</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                                <% } else { %>
                                    <p>No events found.</p>
                                    <% } %>

                </div>

                <hr>

            </div>
            <style>
                canvas {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100vw;
                    height: 100vh;
                    pointer-events: none;
                    z-index: 999;
                }
            </style>
            <%- include('partials/footer.ejs')%>
                <script type="module">

                    import { generateConfetti } from "/js/vanillaConfetti.min.js";

                    const confettiConfigObj = {
                        colorsArray: [
                            "rgba(255, 180, 185, 1)",
                            "rgba(255, 220, 185, 1)",
                            "rgba(255, 255, 185, 1)",
                            "rgba(185, 255, 200, 1)",
                            "rgba(185, 225, 255, 1)",
                            "rgba(215, 185, 255, 1)"
                        ],
                        velocity: 0.025,
                        quantity: 750,
                        minSize: 4,
                        maxSize: 12,
                        minOpacity: 0.75,
                        maxOpacity: 1,
                        infiniteLoop: false
                    };

                    const launch = () => {
                        const canvas = document.getElementById("vanillaConfettiCanvas");
                        if (canvas) {
                            canvas.width = window.innerWidth;
                            canvas.height = window.innerHeight;
                            generateConfetti(confettiConfigObj, "vanillaConfettiCanvas");
                        }
                    };
                    window.addEventListener('load', launch);
                </script>

    </body>

</html>