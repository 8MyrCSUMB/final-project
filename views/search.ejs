<!DOCTYPE html>
<html lang="en">

<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/navbarLoggedIn.ejs')%>

            <form action="/search" method="get">
                <label for="musicName">Search an artist or a music</label>
                <input type="text" name="musicName">
                <button type="submit">Search</button>
            </form>


            <% for (let i=0; i < result.length; i++) { %>
                <%= result[i][0] %>
                    <%= result[i][1] %><img src="<%=result[i][2] %>"> <audio src="<%= result[i][3] %>"
                            controls>preview</audio>
                        <div class="d-flex">
                            <a href="/liked?artistName=<%= result[i][0] %>&musicName=<%= result[i][1] %>"><button
                                    type="button" class="btn btn-primary">Add to liked</button></a>
                        </div>
                        <br>
                        <% } %>

                            <%= message %>

                                <%- include('partials/footer.ejs')%>
    </body>

</html>