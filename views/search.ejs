<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<%- include('partials/head.ejs') %>

    <body>
        <%- include('partials/navbarLoggedIn.ejs')%>

        <div class="container py-5" style="max-width: 700px;">

            <h1 class="fw-bold mb-4 text-center">
                <i class="bi bi-music-note-beamed me-2"></i>Search Songs
            </h1>

            <form action="/search" method="get" class="input-group mb-5">
                <input type="text" name="musicName" class="form-control form-control-lg" placeholder="Artist, song, album…">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="bi bi-search"></i>
                </button>
            </form>

            <% for (let i = 0; i < result.length; i++) { %>
                <div class="card mb-3 border-0 bg-body-secondary">
                    <div class="row g-0 align-items-center">
                        <div class="col-auto">
                            <img src="<%= result[i][2] %>" class="rounded-start" style="width:80px; height:80px; object-fit:cover;">
                        </div>
                        <div class="col px-3">
                            <p class="text-muted small mb-0 text-uppercase fw-semibold"><%= result[i][0] %></p>
                            <p class="fw-bold mb-1"><%= result[i][1] %></p>
                            <audio src="<%= result[i][3] %>" controls style="height:30px; width:100%;"></audio>
                        </div>
                        <div class="col-auto pe-3">
                            <a href="/liked?artistName=<%= result[i][0] %>&musicName=<%= result[i][1] %>"
                               class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-heart-fill"></i>
                            </a>
                        </div>
                    </div>
                </div>
            <% } %>

            <% if (typeof message !== 'undefined' && message) { %>
                <p class="text-center text-muted mt-4"><%= message %></p>
            <% } %>

        </div>

        <%- include('partials/footer.ejs')%>
    </body>

</html>